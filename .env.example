# Neon Postgres connection string (server only).
# Copy this file to .env.local and paste your Neon connection string.
# In the Neon console: Project -> Connection Details -> copy the "Pooled"
# connection string (it ends with ?sslmode=require).
#
# NEVER expose this to the browser or commit it. It is only read in server code
# (the API routes and the Tour page).

DATABASE_URL=postgresql://USER:PASSWORD@ep-xxxx-pooler.REGION.aws.neon.tech/DBNAME?sslmode=require
